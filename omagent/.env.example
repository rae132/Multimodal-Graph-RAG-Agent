# ==========================================
#  多模型路由配置 (Litellm 统一接口)
# ==========================================

# 1. 主聊天与推理模型 (必填)
CHAT_API_KEY=your_api_key_here
CHAT_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_MODEL_ID=openai/qwen-plus

# 2. 知识图谱抽取模型 (选填)
# 如果不填，默认使用 CHAT_MODEL_ID。推荐使用专门的语言模型。
# EXTRACT_MODEL_ID=openai/deepseek-chat

# 3. 多模态视觉模型 (选填)
# 用于支持图片理解
VISION_MODEL_ID=openai/qwen-vl-plus

# 4. 嵌入模型与维度 (必填)
# ⚠️ 注意：更换嵌入模型或维度后，必须删除 rag_storage 目录重新构建索引！
EMBED_API_KEY=your_api_key_here
EMBED_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_MODEL_ID=openai/text-embedding-v3
# 设置为 0 开启自动探测。如果探测失败，可以手动配置，例如 1024 或 3072。
EMBED_DIM=0

# --- RAG & OmAgent 运行配置 ---
RAG_WORKING_DIR=./rag_storage
TIKTOKEN_CACHE_DIR=../tiktoken_cache
PARSER=mineru
PARSE_METHOD=auto
OMAGENT_MODE=lite

# --- Gradio Web 服务监听 ---
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# --- 用户对话模型 ID 设置 (映射到 gpt.yml) ---
custom_openai_key=your_api_key_here
custom_openai_endpoint=https://dashscope.aliyuncs.com/compatible-mode/v1

# 5. Rerank 重排序模型 (可选，默认关闭)
ENABLE_RERANK=true
RERANK_PROVIDER=aliyun
RERANK_MODEL_ID=gte-rerank-v2
RERANK_API_KEY=your_api_key_here
